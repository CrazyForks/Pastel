{
  "name": "@pastel-palette/docs",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm build:starter && tsc && vite build && cp -r public/* dist",
    "build:starter": "cd ../templates/react-starter && npx -y pnpm@11.5.2 install --ignore-workspace && npx vite build --base=/starter/ --outDir ../../docs/public/starter --emptyOutDir",
    "clean": "rm -rf dist build public/starter",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pastel-palette/colors": "workspace:*",
    "@pastel-palette/tailwindcss": "workspace:*",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-portal": "1.1.11",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-slider": "1.4.0",
    "clsx": "^2.1.1",
    "geist": "1.7.2",
    "lucide-react": "1.17.0",
    "motion": "12.40.0",
    "next-themes": "0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "use-context-selector": "2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "code-inspector-plugin": "1.5.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
