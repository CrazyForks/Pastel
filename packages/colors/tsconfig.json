{
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-native",
    "lib": ["ESNext"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ESNext"
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
