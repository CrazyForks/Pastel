{
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "lib": ["ESNext"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "ESNext"
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
